services:
  radarr:
    image: lscr.io/linuxserver/radarr:latest
    container_name: radarr
    restart: unless-stopped
    ports:
      - "7878:7878"
    volumes:
      - ./config:/config
      - /data/media:/data/media
    environment:
      PUID: 1000
      PGID: 1000
      TZ: America/New_York
      RADARR__AUTH__APIKEY: f9e8d7c6b5a4f9e8d7c6b5a4f9e8d7c6

networks:
  default:
    name: arr-net
